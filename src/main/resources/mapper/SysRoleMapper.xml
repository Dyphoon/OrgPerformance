<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cmbchina.orgperformance.mapper.SysRoleMapper">

    <select id="selectById" resultType="com.cmbchina.orgperformance.entity.SysRole">
        SELECT * FROM sys_role WHERE id = #{id}
    </select>

    <select id="selectByCode" resultType="com.cmbchina.orgperformance.entity.SysRole">
        SELECT * FROM sys_role WHERE role_code = #{roleCode}
    </select>

    <select id="selectAll" resultType="com.cmbchina.orgperformance.entity.SysRole">
        SELECT * FROM sys_role
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id"
            parameterType="com.cmbchina.orgperformance.entity.SysRole">
        INSERT INTO sys_role (role_code, role_name, description, created_at)
        VALUES (#{roleCode}, #{roleName}, #{description}, #{createdAt})
    </insert>

</mapper>
